rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ADMIN EMAILS (agregar los tuyos aquí) ──
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          "admin@streamvault.app",
          "fullanuel365@gmail.com"
        ];
    }

    // Cualquier request autenticado puede leer su propio user doc
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── USERS ──
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isAdmin();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    // ── KEYS ──
    match /keys/{keyId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── ACCOUNTS ──
    match /accounts/{platformId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── PAYMENTS ──
    match /payments/{payId} {
      allow read: if isAdmin() || (request.auth != null &&
        resource.data.clienteId == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── TICKETS ──
    match /tickets/{ticketId} {
      allow read: if isAdmin() || (request.auth != null &&
        resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update: if isAdmin() || (request.auth != null &&
        resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── CHATS ──
    match /chats/{chatId} {
      allow read, write: if isAdmin() || request.auth != null;
    }

    // ── RATINGS ──
    match /ratings/{ratingId} {
      allow read: if true; // público (para mostrar en home)
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // ── LOGS ──
    match /logs/{logId} {
      allow read, write: if isAdmin();
    }

    // ── CONFIG ──
    match /config/{docId} {
      allow read: if true; // público (status de servicio)
      allow write: if isAdmin();
    }

    // ── DISCOUNTS ──
    match /discounts/{discountId} {
      allow read: if true; // para validar códigos
      allow write: if isAdmin();
    }

    // ── NOTIFICATIONS ──
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── GRANTED (cuentas otorgadas) ──
    match /granted/{grantId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Bloquear todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
